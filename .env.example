# ═══════════════════════════════════════════════════════
# Verdigris — Environment Configuration
# Copy this file to .env and fill in your API keys
# Never commit .env to version control
# ═══════════════════════════════════════════════════════

# ── LLM via OpenRouter (required) ─────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Recommended models — any OpenRouter model works here
# Sonnet 4.5 gives best report quality (~$0.04/report)
# deepseek-chat is fastest for chat (~$0.001/query)
MODEL_ANALYST=anthropic/claude-sonnet-4-5
MODEL_WRITER=anthropic/claude-sonnet-4-5
MODEL_FAST=deepseek/deepseek-chat

# ── EIA — U.S. electricity rates (required for U.S.) ──
# Free key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=
EIA_BASE_URL=https://api.eia.gov/v2

# ── NREL PVWatts — solar simulation (required for U.S.)
# Free key at https://developer.nrel.gov/signup
NREL_API_KEY=

# ── U.S. Census — demographics (required for U.S.) ────
# Free key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ── Eurostat — EU electricity rates (no key required) ─
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data

# ── Obsidian Vault — knowledge base storage ───────────
# Full path to your Obsidian vault folder, no quotes
# Verdigris will write reports to a Verdigris/ subfolder
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault